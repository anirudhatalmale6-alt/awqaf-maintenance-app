{
    "title": "users",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "maxLength": 255,
            "description": "Primary key, platform sub ID"
        },
        "email": {
            "type": "string",
            "maxLength": 255,
            "description": "User email"
        },
        "name": {
            "type": "string",
            "maxLength": 255,
            "description": "User display name"
        },
        "role": {
            "type": "string",
            "maxLength": 50,
            "description": "User role: user/admin/owner",
            "default": "user"
        },
        "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Account creation time"
        },
        "last_login": {
            "type": "string",
            "format": "date-time",
            "description": "Last login time"
        }
    },
    "required": [
        "id",
        "email"
    ]
}
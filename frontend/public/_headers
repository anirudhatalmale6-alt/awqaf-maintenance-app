# Cache-Control headers for static hosts that respect Netlify-style _headers.
# index.html and service workers must NEVER be cached by the browser, so a
# fresh deploy is picked up immediately on the next page load.
# Hashed assets (JS/CSS/images under /assets/*) are content-addressed by Vite
# and can be cached aggressively.

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/push-sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# pdfjs worker — must be served as JavaScript ESM module, NOT html or octet-stream.
# This is critical for production: some hosts (awqafmaintstaff.com etc.) default
# to the wrong MIME type for `.mjs` and the dynamic `import()` then fails with
# "Failed to fetch dynamically imported module".
/pdf.worker.min.mjs
  Content-Type: text/javascript; charset=utf-8
  Cache-Control: public, max-age=31536000, immutable
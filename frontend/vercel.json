{
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "https://backend-production-b7f3.up.railway.app/api/v1/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}